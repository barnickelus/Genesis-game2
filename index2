// ═══ TAPERED TAIL ═══
function drawTail(ts){
  const n=P.tail.length;if(n<4)return;const s=stg();
  const skip=Math.max(1,Math.floor(n/40));
  const pts=[];for(let i=0;i<n;i+=skip)pts.push({...P.tail[i],t:i/(n-1)});
  if(pts.length<3)return;
  const headW=P.r*.6,tipW=.3;
  const left=[],right=[];
  for(let i=0;i<pts.length;i++){
    const p=pts[i];let tx2,ty2;
    if(i<pts.length-1){tx2=pts[i+1].x-p.x;ty2=pts[i+1].y-p.y;}else{tx2=p.x-pts[i-1].x;ty2=p.y-pts[i-1].y;}
    const tL=Math.hypot(tx2,ty2)||1,nx=-ty2/tL,ny=tx2/tL;
    const eT=p.t*p.t,w=lp(headW,tipW,eT);
    const wave=Math.sin(p.t*10+ts*.007)*w*.12*(1-p.t);
    left.push({x:p.x+nx*(w+wave),y:p.y+ny*(w+wave)});
    right.push({x:p.x-nx*(w-wave),y:p.y-ny*(w-wave)});
  }
  cx.save();
  cx.globalCompositeOperation='lighter';cx.globalAlpha=.05;cx.fillStyle=s.c.dim;cx.shadowBlur=10*zm;cx.shadowColor=s.c.dim;
  cx.beginPath();cx.moveTo(left[0].x,left[0].y);for(let i=1;i<left.length;i++)cx.lineTo(left[i].x,left[i].y);for(let i=right.length-1;i>=0;i--)cx.lineTo(right[i].x,right[i].y);cx.closePath();cx.fill();
  cx.globalCompositeOperation='source-over';cx.shadowBlur=6*zm;cx.shadowColor=s.c.dim;
  const grad=cx.createLinearGradient(pts[0].x,pts[0].y,pts[pts.length-1].x,pts[pts.length-1].y);grad.addColorStop(0,s.c.pri);grad.addColorStop(.3,s.c.dim);grad.addColorStop(1,'transparent');
  cx.globalAlpha=.4;cx.fillStyle=grad;cx.beginPath();cx.moveTo(left[0].x,left[0].y);for(let i=1;i<left.length;i++)cx.lineTo(left[i].x,left[i].y);for(let i=right.length-1;i>=0;i--)cx.lineTo(right[i].x,right[i].y);cx.closePath();cx.fill();
  cx.globalCompositeOperation='lighter';cx.globalAlpha=.12;cx.strokeStyle=s.c.pri;cx.lineWidth=Math.max(.4,headW*.12);cx.lineCap='round';cx.beginPath();cx.moveTo(pts[0].x,pts[0].y);for(let i=1;i<pts.length;i++)cx.lineTo(pts[i].x,pts[i].y);cx.stroke();
  if(P.stg>=3){cx.globalAlpha=.08;cx.fillStyle=s.c.pri;const bS=Math.max(1,Math.floor(pts.length/10));for(let i=1;i<pts.length*.6;i+=bS){const br=lp(headW*.15,.2,pts[i].t*pts[i].t);cx.beginPath();cx.arc(left[i].x,left[i].y,br,0,TAU);cx.fill();}}
  cx.restore();
}

