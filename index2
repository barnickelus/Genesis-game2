// ═══════════════════════════════════════
// FLOCKING (uses spatial grid)
// ═══════════════════════════════════════
function boids(o){
  const T=ORGS[o.type];
  if(!T.school)return{fx:0,fy:0};
  const schR=T.schR||100;
  let sepX=0,sepY=0,sepN=0,aliX=0,aliY=0,cohX=0,cohY=0,n=0;

  const nearby=gridNear(o.x,o.y,schR);
  for(const q of nearby){
    if(q===o||q.type!==o.type)continue;
    const dx=q.x-o.x,dy=q.y-o.y,dd=Math.hypot(dx,dy);
    if(dd>schR||dd<.1)continue;
    if(dd<schR*.35){const w=1-dd/(schR*.35);sepX-=(dx/dd)*w;sepY-=(dy/dd)*w;sepN++;}
    aliX+=Math.cos(q.hd);aliY+=Math.sin(q.hd);
    cohX+=q.x;cohY+=q.y;n++;
  }

  let fx=0,fy=0;
  if(sepN>0){fx+=sepX/sepN*1.8;fy+=sepY/sepN*1.8;}
  if(n>0){fx+=(aliX/n-Math.cos(o.hd))*.6;fy+=(aliY/n-Math.sin(o.hd))*.6;
    const cx2=cohX/n-o.x,cy2=cohY/n-o.y,cd=Math.hypot(cx2,cy2);
    if(cd>1){fx+=(cx2/cd)*.4;fy+=(cy2/cd)*.4;}}

  // Scatter from player
  if(canEat(o)){
    const pd=dst(P,o),flR=100+P.r*2.5;
    if(pd<flR){o.scatterT=800;
      for(const q of nearby)if(q.type===o.type)q.scatterT=Math.max(q.scatterT,600);}
  }
  if(o.scatterT>0){fx*=.2;fy*=.2;const fa=ang(P,o),u=o.scatterT/800;fx+=Math.cos(fa)*3*u;fy+=Math.sin(fa)*3*u;}
  return{fx,fy};
}

function schoolPulse(o){
  const nearby=gridNear(o.x,o.y,ORGS[o.type].schR||100);
  for(const q of nearby){
    if(q===o||q.type!==o.type)continue;
    o.breathPh+=Math.sin(q.breathPh-o.breathPh)*.02;
    break; // sync with one neighbor
  }
}

// ═══ ECOSYSTEM PREY SEARCH (spatial grid) ═══
function findOrgPrey(o){
  const preyTypes=PREY_OF[o.type];if(!preyTypes)return null;
  const huntR=ECO_HUNT_R[o.type]||120;
  const nearby=gridNear(o.x,o.y,huntR);
  let best=null,bestD=huntR;
  for(const q of nearby){
    if(q===o||!preyTypes.includes(q.type)||q.r>=o.r*.9)continue;
    const dd=dst(o,q);if(dd<bestD){bestD=dd;best=q;}
  }
  return best;
}

// ═══ AI ═══
function aiOrg(o,dt){
  const T=ORGS[o.type],dist=dst(P,o);
  const smaller=canEat(o),bigger=isPred(o);
  const spd=T.spd*(o.stunT>0?.15:1);

  // Timers
  o.stT-=dt;o.stunT=Math.max(0,o.stunT-dt);o.flT=Math.max(0,o.flT-dt);
  o.ph+=dt*.003;o.finPh+=dt*.006;o.breathPh+=dt*.004;
  o.scatterT=Math.max(0,o.scatterT-dt);

  // Eye tracking
  const te=ang(o,P),ed=Math.atan2(Math.sin(te-o.eyeAng),Math.cos(te-o.eyeAng));
  o.eyeAng+=ed*Math.min(1,dt*.005);

  // Trail
  if(Math.random()<.04&&o.trail.length<6)o.trail.push({x:o.x,y:o.y,l:250});
  for(let i=o.trail.length-1;i>=0;i--){o.trail[i].l-=dt;if(o.trail[i].l<=0)o.trail.splice(i,1);}

  if(T.school)schoolPulse(o);

  let tx=o.x,ty=o.y;
  const fleeR=smaller?100+P.r*2.5:0;
  const huntR=bigger?180+o.r*3:0;

  // ── Behavior switch ──
  switch(T.beh){
    case'bloom':{
      o.wAng+=(Math.random()-.5)*.008*dt;
      tx=o.x+Math.cos(o.wAng)*spd;ty=o.y+Math.sin(o.wAng)*spd;
      break;}
    case'drift':{
      o.wAng+=(Math.random()-.5)*.03*dt;
      tx=o.x+Math.cos(o.wAng)*spd;ty=o.y+Math.sin(o.wAng)*spd;
      if(smaller&&dist<fleeR){const fa=ang(P,o),u=1-dist/fleeR;tx=o.x+Math.cos(fa)*spd*(2+u*4);ty=o.y+Math.sin(fa)*spd*(2+u*4);}
      break;}
    case'swarm':{
      o.wAng+=(Math.random()-.5)*.04*dt;
      tx=o.x+Math.cos(o.wAng)*spd*.5;ty=o.y+Math.sin(o.wAng)*spd*.5;
      if(smaller&&dist<fleeR){const fa=ang(P,o),u=1-dist/fleeR;tx=o.x+Math.cos(fa)*spd*(3+u*4);ty=o.y+Math.sin(fa)*spd*(3+u*4);}
      break;}
    case'pulse':{
      const ps=Math.sin(o.breathPh*2)*spd*2;
      tx=o.x+Math.cos(o.hd)*ps;ty=o.y+Math.sin(o.hd)*ps;
      if(o.stT<=0){o.hd+=(Math.random()-.5)*1.5;o.stT=rng(1000,2500);}
      if(smaller&&dist<fleeR){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*3;ty=o.y+Math.sin(fa)*spd*3;}
      break;}
    case'chase':{
      if(bigger&&dist<huntR){const ha=ang(o,P);tx=o.x+Math.cos(ha)*spd*(dist<100?1.8:1.2);ty=o.y+Math.sin(ha)*spd*(dist<100?1.8:1.2);}
      else if(smaller&&dist<fleeR){const fa=ang(P,o),zz=Math.sin(gt*.005)*.6;tx=o.x+Math.cos(fa+zz)*spd*2.8;ty=o.y+Math.sin(fa+zz)*spd*2.8;}
      else{o.wAng+=(Math.random()-.5)*.03*dt;tx=o.x+Math.cos(o.wAng)*spd*.5;ty=o.y+Math.sin(o.wAng)*spd*.5;}
      break;}
    case'ambush':{
      if(smaller&&dist<fleeR){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*3;ty=o.y+Math.sin(fa)*spd*3;o.ambR=false;o.stT=2000;}
      else if(o.ambR){o.lAng+=dt*.003;if((bigger||(!smaller&&!bigger))&&dist<65){o.ambR=false;o.stT=2200;const ha=ang(o,P);o.vx=Math.cos(ha)*6;o.vy=Math.sin(ha)*6;burst(o.x,o.y,T.col,6,2);shk(2,50);}}
      else{o.wAng+=(Math.random()-.5)*.02*dt;tx=o.x+Math.cos(o.wAng)*spd;ty=o.y+Math.sin(o.wAng)*spd;if(o.stT<=0)o.ambR=true;}
      break;}
    case'passive':{
      o.wAng+=(Math.random()-.5)*.006*dt;tx=o.x+Math.cos(o.wAng)*spd;ty=o.y+Math.sin(o.wAng)*spd;
      if(smaller&&dist<fleeR*.7){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*2;ty=o.y+Math.sin(fa)*spd*2;}
      if(o.flT>0&&bigger&&dist<250){const ha=ang(o,P);tx=o.x+Math.cos(ha)*spd*2.5;ty=o.y+Math.sin(ha)*spd*2.5;}
      break;}
    case'lure':{
      if(smaller&&dist<fleeR){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*2.5;ty=o.y+Math.sin(fa)*spd*2.5;}
      else if(bigger){if(dist>250){if(Math.random()<.007&&parts.length<180)parts.push({x:lp(o.x,P.x,.6)+rng(-20,20),y:lp(o.y,P.y,.6)+rng(-20,20),vx:0,vy:0,r:3,life:1500,ml:1500,c:C.prey,t:'lure'});const ha=ang(o,P);tx=o.x+Math.cos(ha)*spd*.4;ty=o.y+Math.sin(ha)*spd*.4;}else{const ha=ang(o,P);tx=o.x+Math.cos(ha)*spd*2;ty=o.y+Math.sin(ha)*spd*2;}}
      else{o.wAng+=(Math.random()-.5)*.03*dt;tx=o.x+Math.cos(o.wAng)*spd;ty=o.y+Math.sin(o.wAng)*spd;}
      break;}
    case'apex':{
      if(smaller&&dist<fleeR){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*3;ty=o.y+Math.sin(fa)*spd*3;}
      else if(bigger&&dist<huntR){const px=P.x+P.vx*30,py=P.y+P.vy*30,ha=Math.atan2(py-o.y,px-o.x);tx=o.x+Math.cos(ha)*spd*1.6;ty=o.y+Math.sin(ha)*spd*1.6;if(dist<150&&o.stT<=0){o.vx=Math.cos(ha)*5;o.vy=Math.sin(ha)*5;o.stT=1800;burst(o.x,o.y,T.col,8,3);shk(3,80);}}
      else{const oa=ang(o,P)+PI/3;tx=o.x+Math.cos(oa)*spd;ty=o.y+Math.sin(oa)*spd;}
      break;}
    case'mirror':{
      if(smaller&&dist<fleeR){const fa=ang(P,o);tx=o.x+Math.cos(fa)*spd*2.5;ty=o.y+Math.sin(fa)*spd*2.5;}
      else if(behMem.length>=10){const s=behMem[rni(0,behMem.length)];const ch=Math.sin(gt*.002)*.7;tx=o.x+s.vx*-1+Math.sin(gt*.003+o.x)*ch;ty=o.y+s.vy*-1+Math.cos(gt*.003+o.y)*ch;if(Math.random()<.012){const ha=ang(o,P);o.vx+=Math.cos(ha)*4;o.vy+=Math.sin(ha)*4;}}
      break;}
  }

  // ── Ecosystem: hunt prey organisms when player isn't priority ──
  const playerFar=dist>fleeR*1.5&&dist>huntR*1.2;
  if(playerFar&&PREY_OF[o.type]){
    const prey=findOrgPrey(o);
    if(prey){const ha=ang(o,prey);tx=lp(tx,o.x+Math.cos(ha)*spd*1.5,.4);ty=lp(ty,o.y+Math.sin(ha)*spd*1.5,.4);}
  }

  // ── Ecosystem: flee from organism predators ──
  if(T.school||T.beh==='drift'||T.beh==='bloom'){
    const nearby=gridNear(o.x,o.y,120);
    for(const pred of nearby){
      if(pred===o)continue;
      const pp=PREY_OF[pred.type];
      if(!pp||!pp.includes(o.type)||pred.r<o.r*.9)continue;
      const pd=dst(o,pred),orgFleeR=60+pred.r*2;
      if(pd<orgFleeR){const fa=ang(pred,o),u=1-pd/orgFleeR;tx+=Math.cos(fa)*spd*(1+u*2);ty+=Math.sin(fa)*spd*(1+u*2);break;}
    }
  }

  // Apply flocking + movement
  const flock=boids(o);
  o.vx=o.vx*.9+((tx-o.x)*.04+flock.fx*.3);
  o.vy=o.vy*.9+((ty-o.y)*.04+flock.fy*.3);
  o.x+=o.vx*(dt/16);o.y+=o.vy*(dt/16);
  o.hd=Math.atan2(o.vy,o.vx);

  // Respawn if far
  if(dst(P,o)>2200){const a=Math.random()*TAU,dd=rng(500,T.spW);o.x=P.x+Math.cos(a)*dd;o.y=P.y+Math.sin(a)*dd;o.hp=o.mhp;o.ambR=T.beh==='ambush';}
}

// ═══ PLAYER ═══
function updateP(dt){
  const s=stg();let dx=0,dy=0;
  if(jkAct){ptr.x=P.x+jkX*100;ptr.y=P.y+jkY*100;ptr.on=true;}
  if(ptr.on){dx=ptr.x-P.x;dy=ptr.y-P.y;}
  const dL=Math.hypot(dx,dy);if(dL>.5)P.hd=Math.atan2(dy,dx);
  if(ptr.tap&&s.ab&&s.cd>0)useAbil();
  ptr.tap=false;

  let spd=s.spd*(1+Math.log2(Math.max(1,P.mass))*.08);
  if(P.dash){spd*=2.5;P.dashT-=dt;if(P.dashT<=0)P.dash=false;}
  if(P.boost>0){spd*=1.2;P.boost=Math.max(0,P.boost-dt);}
  if(dL>2){P.vx=lp(P.vx,dx/dL*spd,.1);P.vy=lp(P.vy,dy/dL*spd,.1);}else{P.vx*=.9;P.vy*=.9;}
  P.x+=P.vx*(dt/16);P.y+=P.vy*(dt/16);

  P.r=calcR(P.mass,s.bR);
  const floor=STAGES[P.stg].thr*.85+3;
  P.mass=Math.max(floor,P.mass-calcDecay(P.mass,dt));

  P.tail.unshift({x:P.x,y:P.y});
  while(P.tail.length>Math.floor(16+Math.log2(Math.max(1,P.mass))*8))P.tail.pop();

  P.blink=Math.max(0,P.blink-dt);abil_cd=Math.max(0,abil_cd-dt);
  if(P.flash.t>0)P.flash.t-=dt;
  streakT=Math.max(0,streakT-dt);if(streakT<=0)streak=0;

  // Passives
  if(s.ab==='sting'){const nearby=gridNear(P.x,P.y,P.r*3);for(const o of nearby){if(o.r<P.r*.8&&dst(P,o)<P.r*3){o.stunT=Math.max(o.stunT,400);if(Math.random()<.02){o.hp--;o.flT=120;}}}}
  if(s.ab==='gravity'){const nearby=gridNear(P.x,P.y,P.r*6);for(const o of nearby){const dd=dst(P,o);if(dd<P.r*6&&o.r<P.r*.8){const ps=.5*(1-dd/(P.r*6)),a=ang(o,P);o.vx+=Math.cos(a)*ps;o.vy+=Math.sin(a)*ps;}}}

  behMem.push({vx:P.vx,vy:P.vy,hd:P.hd});if(behMem.length>120)behMem.shift();
}

// ═══ ABILITIES ═══
function useAbil(){
  if(abil_cd>0)return;const s=stg();if(!s.ab||s.cd===0)return;
  switch(s.ab){
    case'dash':P.dash=true;P.dashT=180;abil_cd=s.cd;burst(P.x,P.y,s.c.pri,6,2.5);shk(1.5,50);break;
    case'whip':{
      abil_cd=s.cd;const wR=P.r*4.5,bA=P.hd+PI;
      const nearby=gridNear(P.x,P.y,wR);
      for(const o of nearby){const d=dst(P,o);if(d<wR){const a=ang(P,o),df=Math.abs(Math.atan2(Math.sin(a-bA),Math.cos(a-bA)));if(df<PI*.55){o.hp-=3;o.flT=200;o.stunT=600;o.vx+=Math.cos(a)*8;o.vy+=Math.sin(a)*8;burst(o.x,o.y,C.naga.pri,4,1.5);}}}
      for(let i=0;i<16;i++){const a=bA-PI*.55+(i/16)*PI*1.1,d=wR*rng(.4,1);parts.push({x:P.x+Math.cos(a)*d,y:P.y+Math.sin(a)*d,vx:Math.cos(a)*2,vy:Math.sin(a)*2,r:2,life:250,ml:250,c:C.naga.pri,t:'c'});}
      shk(4,150);snd('sfxHurt');break;}
    case'bolt':{
      abil_cd=s.cd;const a=ang(P,ptr.on?ptr:{x:P.x+Math.cos(P.hd)*100,y:P.y+Math.sin(P.hd)*100});
      projs.push({x:P.x+Math.cos(a)*P.r,y:P.y+Math.sin(a)*P.r,vx:Math.cos(a)*8,vy:Math.sin(a)*8,r:4,life:1200,dmg:8,c:C.primo.pri});
      burst(P.x+Math.cos(a)*P.r,P.y+Math.sin(a)*P.r,C.primo.pri,4,1.2);shk(1.5,40);break;}
  }
}

// ═══ EVOLUTION ═══
function checkEvo(){
  if(P.stg<STAGES.length-1&&P.mass>=STAGES[P.stg+1].thr){
    P.stg++;const s=stg();
    document.getElementById('evoFlash').style.background=`radial-gradient(circle,${s.c.pri}55 0%,transparent 70%)`;
    document.getElementById('evoFlash').style.opacity='1';setTimeout(()=>document.getElementById('evoFlash').style.opacity='0',300);
    document.getElementById('evoT').textContent=s.name;document.getElementById('evoT').style.color=s.c.pri;
    document.getElementById('evoS').textContent=s.desc;document.getElementById('evoAnn').style.opacity='1';
    setTimeout(()=>document.getElementById('evoAnn').style.opacity='0',3000);
    burst(P.x,P.y,s.c.pri,35,5);ring(P.x,P.y,'#fff',P.r*2,16);shk(8,400);snd('sfxEvo');
    if(P.stg>=2)spawn('hunter',3);
    if(P.stg>=3){spawn('phantom',2);if(Math.random()<.5)spawn('echo',1);}
    if(P.stg>=4){spawn('levia',2);spawn('behemoth',1);spawn('echo',1);}
    if(P.stg>=5)spawn('behemoth',2);
  }
}

// ═══ COLLISIONS ═══
function collide(dt){
  // Player eats / gets hurt
  const nearP=gridNear(P.x,P.y,Math.max(P.r*2,80));
  for(let i=nearP.length-1;i>=0;i--){
    const o=nearP[i];if(!orgs.includes(o))continue;
    const dist=dst(P,o);
    if(canEat(o)&&dist<P.r){
      const T=ORGS[o.type],gain=calcGain(T.mass,P.mass);
      P.mass+=gain;score+=Math.floor(gain*8);streak++;streakT=2500;
      burst(o.x,o.y,T.col,8,1.8);fTxt(o.x,o.y-10,'+'+Math.floor(gain),T.col);
      if(streak>2)fTxt(o.x,o.y-24,streak+'x','rgba(255,255,255,.5)');
      shk(.6+o.r*.06,50);snd('sfxEat');
      const idx=orgs.indexOf(o);if(idx>=0)orgs.splice(idx,1);
      const cnt=orgs.filter(q=>q.type===o.type).length;
      if(cnt<ORGS[o.type].mx)setTimeout(()=>spawn(o.type,1),rng(1500,4000));
      checkEvo();continue;
    }
    if(isPred(o)&&dist<o.r&&P.blink<=0&&!shOn){
      P.mass=Math.max(5,P.mass-ORGS[o.type].mass*.08*(dt/16));P.blink=250;
      shk(2.5,80);burst(P.x,P.y,'#ff2244',4,1.2);snd('sfxHurt');
      if(P.stg>0&&P.mass<STAGES[P.stg].thr*.55){P.stg=Math.max(0,P.stg-1);fTxt(P.x,P.y-28,'DE-EVOLVED','#ff4444');shk(6,300);}
    }
    if(o.hp<=0){
      const T=ORGS[o.type],gain=calcGain(T.mass*.4,P.mass);
      P.mass+=gain;score+=Math.floor(gain*5);
      burst(o.x,o.y,T.col,12,2.5);fTxt(o.x,o.y-10,'+'+Math.floor(gain),T.col);
      const idx=orgs.indexOf(o);if(idx>=0)orgs.splice(idx,1);checkEvo();
    }
  }

  // Projectiles
  for(let i=projs.length-1;i>=0;i--){
    const p=projs[i];p.x+=p.vx;p.y+=p.vy;p.life-=16;
    if(parts.length<200)parts.push({x:p.x,y:p.y,vx:rng(-.15,.15),vy:rng(-.15,.15),r:rng(.5,2),life:140,ml:140,c:p.c,t:'c'});
    if(p.life<=0){projs.splice(i,1);continue;}
    const nearby=gridNear(p.x,p.y,30);
    for(const o of nearby){
      if(dst(p,o)<o.r+p.r){o.hp-=p.dmg;o.flT=180;o.stunT=300;o.vx+=p.vx*.3;o.vy+=p.vy*.3;burst(p.x,p.y,p.c,6,1.5);projs.splice(i,1);break;}
    }
  }

  // ── FRENZY PILL ──
  if(pill.on&&dst(P,pill)<P.r+pill.r){
    P.flash={c:'#40c8f0',t:400};frenzy=true;fTime=8000;pill.on=false;snd('sfxEvo');
    burst(pill.x,pill.y,'#40c8f0',14,2.5);shk(3,150);
    // Spawn orbiting frenzy food
    frenzyOrbs=[];
    for(let i=0;i<30;i++){
      const a=rng(0,TAU),R=rng(80,180);
      frenzyOrbs.push({ang:a,dist:R,angSpd:rng(.003,.006)*(Math.random()<.5?1:-1),r:rng(3,5.5),mass:rng(4,8),col:['#ff39ff','#40c8f0','#80e860','#ffee44'][rni(0,4)]});
    }
  }
  if(frenzy){
    fTime-=dt;if(fTime<=0){frenzy=false;frenzyOrbs=[];}
    // Update + check orb collisions
    for(let i=frenzyOrbs.length-1;i>=0;i--){
      const orb=frenzyOrbs[i];
      orb.ang+=orb.angSpd*dt;
      const ox=P.x+Math.cos(orb.ang)*orb.dist;
      const oy=P.y+Math.sin(orb.ang)*orb.dist;
      if(Math.hypot(ox-P.x,oy-P.y)<P.r+orb.r){
        P.mass+=orb.mass;score+=Math.floor(orb.mass*5);
        burst(ox,oy,orb.col,5,1.5);frenzyOrbs.splice(i,1);
      }
    }
  }
  if(!pill.on&&!frenzy){pill.cd+=dt;if(pill.cd>22000+rng(0,8000)){pill={x:P.x+rng(-600,600),y:P.y+rng(-600,600),r:9,on:true,cd:0};}}

  // ── SHIELD ──
  if(shld.on&&dst(P,shld)<P.r+shld.r){P.flash={c:'#e8c040',t:400};shOn=true;shTime=5000;shld.on=false;snd('sfxEat');burst(shld.x,shld.y,'#e8c040',12,2);shk(2,100);}
  if(shOn){shTime-=dt;if(shTime<=0)shOn=false;}
  if(!shld.on&&!shOn){shld.cd+=dt;if(shld.cd>25000+rng(0,10000)){shld={x:P.x+rng(-600,600),y:P.y+rng(-600,600),r:9,on:true,cd:0};}}

  // ── BEACONS ──
  for(let i=beacons.length-1;i>=0;i--){
    if(dst(P,beacons[i])<P.r+beacons[i].r){beacons.length=0;radarOn=true;document.getElementById('radarWrap').style.display='block';burst(P.x,P.y,'#fff',12,2);shk(2,60);break;}
  }
}

// ═══ ECOSYSTEM COLLISIONS ═══
function ecoCollide(){
  // Limit: max 5 kills per frame for perf
  let kills=0;
  for(let i=orgs.length-1;i>=0&&kills<5;i--){
    const a=orgs[i];if(!a)continue;
    const pp=PREY_OF[a.type];if(!pp)continue;
    const nearby=gridNear(a.x,a.y,a.r*2);
    for(const b of nearby){
      if(b===a||!pp.includes(b.type)||b.r>=a.r*.8)continue;
      if(dst(a,b)<a.r+b.r*.3){
        a.r=Math.min(a.r*1.02,ORGS[a.type].maxR*1.1);
        burst(b.x,b.y,ORGS[b.type].col,5,1.2);
        const idx=orgs.indexOf(b);if(idx>=0)orgs.splice(idx,1);
        if(idx<i)i--;
        const cnt=orgs.filter(q=>q.type===b.type).length;
        if(cnt<ORGS[b.type].mx)setTimeout(()=>spawn(b.type,1),rng(2000,5000));
        kills++;break;
      }
    }
  }
}

