<script>
// ═══════════════════════════════════════════════════════════════
// GENESIS EVOLUTION — CLEAN REBUILD
// ═══════════════════════════════════════════════════════════════

const TILE=window.TILE,SCALE=window.SCALE,COLS=window.COLS,ROWS=window.ROWS;
const G=document.getElementById('game'),cx=G.getContext('2d',{alpha:false});
let W,H;function resize(){W=G.width=innerWidth;H=G.height=innerHeight;}
addEventListener('resize',resize);resize();

// ═══ MATH ═══
const TAU=Math.PI*2,PI=Math.PI;
const rng=(a,b)=>a+Math.random()*(b-a);
const rni=(a,b)=>Math.floor(rng(a,b));
const lp=(a,b,t)=>a+(b-a)*t;
const cl=(v,lo,hi)=>Math.max(lo,Math.min(hi,v));

// Distance/angle between objects with .x,.y
function dst(a,b){return Math.hypot(b.x-a.x,b.y-a.y);}
function ang(a,b){return Math.atan2(b.y-a.y,b.x-a.x);}

// On-screen check (requires P, W, H, zm globals)
function onScr(x,y,r){
  const hw=W/(2*zm),hh=H/(2*zm);
  return x+r>P.x-hw&&x-r<P.x+hw&&y+r>P.y-hh&&y-r<P.y+hh;
}

// ═══ SPATIAL HASH GRID ═══
// Divides world into cells for O(1) neighbor lookups
const CELL=150; // cell size
let grid={};

function gridKey(x,y){return((x/CELL|0)+5000)+','+((y/CELL|0)+5000);}

function gridInsert(o){
  const k=gridKey(o.x,o.y);
  if(!grid[k])grid[k]=[];
  grid[k].push(o);
}

function gridNear(x,y,radius){
  const result=[];
  const cr=Math.ceil(radius/CELL);
  const cx0=(x/CELL|0),cy0=(y/CELL|0);
  for(let dx=-cr;dx<=cr;dx++)for(let dy=-cr;dy<=cr;dy++){
    const k=(cx0+dx+5000)+','+(cy0+dy+5000);
    const cell=grid[k];
    if(cell)for(const o of cell)result.push(o);
  }
  return result;
}

function rebuildGrid(){
  grid={};
  for(const o of orgs)gridInsert(o);
}

// ═══ CORE EQUATIONS ═══
function calcR(mass,bR){return bR+Math.log2(Math.max(1,mass))*2.8;}
function calcGain(bm,pm){return bm*(1/(1+pm*.003));}
function calcDecay(m,dt){
  if(m<80)return .0005*dt;
  if(m<400)return(.0008+(m-80)*.000006)*dt;
  if(m<1500)return(.002+(m-400)*.00008)*dt;
  return(.0108+(m-1500)*.0002)*dt;
}
function canEat(o){return o.r<P.r*.8;}
function isPred(o){return o.r>P.r*1.2;}

// ═══ PALETTE ═══
const C={
  mote:{pri:'#60f0b0',dim:'#1c4838',gl:'rgba(96,240,176,'},
  drifter:{pri:'#40c8e8',dim:'#144858',gl:'rgba(64,200,232,'},
  medusa:{pri:'#a880e0',dim:'#2c1c60',gl:'rgba(168,128,224,'},
  naga:{pri:'#e87040',dim:'#481c10',gl:'rgba(232,112,64,'},
  titan:{pri:'#4090e0',dim:'#142048',gl:'rgba(64,144,224,'},
  primo:{pri:'#e8c040',dim:'#483c08',gl:'rgba(232,192,64,'},
  bloom:'#38d8a0',bloomD:'#143828',
  prey:'#80e860',preyD:'#244818',
  cell:'#d0d840',cellD:'#404808',
  jelly:'#e068a8',jellyD:'#38102c',
  hunt:'#e84040',huntD:'#380808',
  lurk:'#d88030',lurkD:'#382008',
  whale:'#5898d8',whaleD:'#142440',
  phant:'#c058e0',phantD:'#280c40',
  apex:'#d82818',apexD:'#380404',
  mirr:'#e0f0f8',mirrGl:'#40e0f0'
};

// ═══ STAGES ═══
const STAGES=[
  {name:'MOTE',thr:0,next:120,c:C.mote,spd:2.8,bR:6,desc:'Consume to grow.',ab:null,abT:'',cd:0},
  {name:'DRIFTER',thr:120,next:400,c:C.drifter,spd:3.2,bR:7,desc:'Tap to dash.',ab:'dash',abT:'TAP — Dash',cd:700},
  {name:'MEDUSA',thr:400,next:1100,c:C.medusa,spd:2.4,bR:8,desc:'Sting aura.',ab:'sting',abT:'Sting aura',cd:0},
  {name:'NAGA',thr:1100,next:2800,c:C.naga,spd:3.4,bR:7,desc:'Tap to lash.',ab:'whip',abT:'TAP — Whip',cd:1000},
  {name:'TITAN',thr:2800,next:6000,c:C.titan,spd:2.2,bR:9,desc:'Gravity well.',ab:'gravity',abT:'Gravity well',cd:0},
  {name:'PRIMORDIAL',thr:6000,next:1/0,c:C.primo,spd:2.8,bR:8,desc:'Tap to fire.',ab:'bolt',abT:'TAP — Bolt',cd:400}
];

// ═══ ORGANISM DEFINITIONS ═══
const ORGS={
  bloom:  {col:C.bloom, dim:C.bloomD, minR:4,maxR:7,   spd:.04, hp:1, mass:8,  beh:'bloom',  spW:500, mx:10},
  mote:   {col:C.prey,  dim:C.preyD,  minR:2.5,maxR:5.5,spd:.25,hp:1, mass:5,  beh:'drift',  spW:700, mx:55, school:true,schR:90},
  polyp:  {col:C.cell,  dim:C.cellD,  minR:5,maxR:9,   spd:.5,  hp:2, mass:12, beh:'swarm',  spW:850, mx:28, school:true,schR:110},
  tendril:{col:C.jelly, dim:C.jellyD, minR:8,maxR:14,  spd:.4,  hp:4, mass:22, beh:'pulse',  spW:950, mx:12, school:true,schR:130},
  hunter: {col:C.hunt,  dim:C.huntD,  minR:12,maxR:22, spd:1.5, hp:8, mass:35, beh:'chase',  spW:1100,mx:8},
  lurker: {col:C.lurk,  dim:C.lurkD,  minR:14,maxR:26, spd:.3,  hp:11,mass:50, beh:'ambush', spW:1300,mx:5},
  levia:  {col:C.whale, dim:C.whaleD, minR:30,maxR:50, spd:.6,  hp:30,mass:90, beh:'passive',spW:1500,mx:3},
  phantom:{col:C.phant, dim:C.phantD, minR:16,maxR:30, spd:1,   hp:18,mass:60, beh:'lure',   spW:1400,mx:4},
  behemoth:{col:C.apex, dim:C.apexD,  minR:40,maxR:65, spd:1.2, hp:50,mass:140,beh:'apex',   spW:1800,mx:2},
  echo:   {col:C.mirr,  dim:'#384848',minR:11,maxR:20, spd:1,   hp:18,mass:65, beh:'mirror', spW:1100,mx:2}
};

// ═══ FOOD CHAIN ═══
const PREY_OF={
  hunter:['mote','polyp','bloom'],
  lurker:['mote','polyp','tendril'],
  phantom:['mote','polyp','tendril'],
  behemoth:['mote','polyp','tendril','hunter','lurker','phantom'],
  levia:['bloom','mote'],
  tendril:['mote','bloom'],
  echo:['mote','polyp']
};
const ECO_HUNT_R={hunter:180,lurker:100,phantom:150,behemoth:250,levia:120,tendril:80,echo:140};

// ═══ GAME STATE ═══
let P;          // player
let orgs=[];    // organisms
let projs=[];   // projectiles
let parts=[];   // particles (pool, max 200)
let txts=[];    // float texts
let dust=[];    // ambient dust

let paused=false, gt=0, score=0;
let shx=0, shy=0, shi=0, shd=0; // screen shake
let abil_cd=0, streak=0, streakT=0;
let off={x:0,y:0}, zm=1;
let muted=false, radarOn=false;
let jkAct=false, jkX=0, jkY=0;
let behMem=[]; // mirror memory

// Pickups
let pill={x:0,y:0,r:9,on:false,cd:0};
let shld={x:0,y:0,r:9,on:false,cd:0};
let frenzy=false, fTime=0;
let frenzyOrbs=[]; // orbiting food during frenzy
let shOn=false, shTime=0;
let beacons=[];

// ═══ INIT ═══
function init(){
  P={x:0,y:0,r:6,mass:10,vx:0,vy:0,hd:0,stg:0,
     tail:[],blink:0,dash:false,dashT:0,boost:0,
     flash:{c:'#fff',t:0}};
  orgs=[];projs=[];parts=[];txts=[];dust=[];frenzyOrbs=[];
  score=0;abil_cd=0;streak=0;streakT=0;gt=0;behMem=[];
  frenzy=false;fTime=0;shOn=false;shTime=0;
  pill={x:0,y:0,r:9,on:false,cd:0};
  shld={x:0,y:0,r:9,on:false,cd:0};
  beacons=[];
  [{x:0,y:-1400},{x:0,y:1400},{x:1400,y:0},{x:-1400,y:0}].forEach(p=>beacons.push({...p,r:14}));

  spawn('bloom',10);spawn('mote',45);spawn('polyp',22);spawn('tendril',8);
  spawn('hunter',4);spawn('lurker',2);spawn('levia',2);spawn('phantom',2);spawn('behemoth',1);

  for(let i=0;i<50;i++)dust.push({
    x:rng(-1500,1500),y:rng(-1500,1500),
    s:rng(.2,1),vx:rng(-.03,.03),vy:rng(-.03,.03),
    a:rng(.012,.05),ph:rng(0,TAU)
  });
}

function spawn(type,n){
  const T=ORGS[type];
  for(let i=0;i<n;i++){
    if(type==='echo'&&orgs.filter(o=>o.type==='echo').length>=2)return;
    const r=rng(T.minR,T.maxR);
    const a=Math.random()*TAU;
    const d=rng(type==='bloom'?60:180,T.spW);
    orgs.push({
      type, x:P.x+Math.cos(a)*d, y:P.y+Math.sin(a)*d,
      r, br:r, hp:T.hp, mhp:T.hp,
      vx:0, vy:0, hd:Math.random()*TAU,
      stT:0, stunT:0, wAng:Math.random()*TAU,
      ph:rng(0,TAU), ambR:type==='lurker',
      lAng:rng(0,TAU), trail:[], flT:0,
      hueShift:rng(-12,12),
      finPh:rng(0,TAU), breathPh:rng(0,TAU),
      eyeAng:0, scatterT:0,
      lobes:type==='bloom'?Array.from({length:5},()=>({a:rng(0,TAU),d:rng(.25,.4),r:rng(.45,.6),ph:rng(0,TAU)})):null
    });
  }
}

function stg(){return STAGES[P.stg];}

// ═══ INPUT ═══
let ptr={x:0,y:0,on:false,tap:false};
const tw=e=>({x:(e.clientX-off.x)/zm,y:(e.clientY-off.y)/zm});
G.addEventListener('pointerdown',e=>{if(paused)return;ptr.on=true;ptr.tap=true;const w=tw(e);ptr.x=w.x;ptr.y=w.y;});
G.addEventListener('pointermove',e=>{if(!ptr.on||paused)return;const w=tw(e);ptr.x=w.x;ptr.y=w.y;});
G.addEventListener('pointerup',()=>ptr.on=false);

document.getElementById('pauseBtn').onclick=()=>{paused=!paused;document.getElementById('pauseMenu').style.display=paused?'flex':'none';};
document.getElementById('resumeBtn').onclick=()=>{paused=false;document.getElementById('pauseMenu').style.display='none';};
document.getElementById('restartBtn').onclick=()=>{paused=false;document.getElementById('pauseMenu').style.display='none';init();};
document.getElementById('muteBtn').onclick=()=>{muted=!muted;document.getElementById('muteBtn').textContent=muted?'Unmute':'Mute';};
document.getElementById('radarBtn').onclick=()=>{radarOn=!radarOn;document.getElementById('radarWrap').style.display=radarOn?'block':'none';};

const jC=document.getElementById('joystickC'),jctx=jC?.getContext('2d');
jC?.addEventListener('touchstart',e=>{if(paused)return;e.preventDefault();const t=e.touches[0],r2=jC.getBoundingClientRect();jkX=(t.clientX-r2.left-50)/50;jkY=(t.clientY-r2.top-50)/50;const L=Math.hypot(jkX,jkY);if(L>1){jkX/=L;jkY/=L;}jkAct=true;ptr.on=true;});
jC?.addEventListener('touchmove',e=>{e.preventDefault();const t=e.touches[0],r2=jC.getBoundingClientRect();jkX=(t.clientX-r2.left-50)/50;jkY=(t.clientY-r2.top-50)/50;const L=Math.hypot(jkX,jkY);if(L>1){jkX/=L;jkY/=L;}});
jC?.addEventListener('touchend',()=>{jkAct=false;jkX=jkY=0;ptr.on=false;});
if(/Mobi|Android/i.test(navigator.userAgent))document.getElementById('joystick').style.display='block';

function snd(id){const s=document.getElementById(id);if(s&&!muted){s.currentTime=0;s.play().catch(()=>{});}}
addEventListener('touchstart',()=>{const b=document.getElementById('bgm');if(b&&b.paused&&!muted)b.play().catch(()=>{});},{once:true});
addEventListener('pointerdown',()=>{const b=document.getElementById('bgm');if(b&&b.paused&&!muted)b.play().catch(()=>{});},{once:true});

// ═══ FX HELPERS ═══
function burst(x,y,c,n=10,s=2){
  for(let i=0;i<n&&parts.length<200;i++){
    const a=Math.random()*TAU,sp=rng(.3,s);
    parts.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp,r:rng(.5,3),life:rng(200,500),ml:500,c,t:'c'});
  }
}
function ring(x,y,c,rad,n=12){
  for(let i=0;i<n&&parts.length<200;i++){
    const a=(i/n)*TAU;
    parts.push({x:x+Math.cos(a)*rad,y:y+Math.sin(a)*rad,vx:Math.cos(a)*1,vy:Math.sin(a)*1,r:1.5,life:300,ml:300,c,t:'c'});
  }
}
function fTxt(x,y,t,c){if(txts.length<30)txts.push({x,y,t,c,life:900,ml:900});}
function shk(i,d){shi=Math.max(shi,i);shd=Math.max(shd,d);}

function bioGlow(x,y,r,col,a){
  if(!onScr(x,y,r*2))return;
  cx.globalAlpha=a;
  const g=cx.createRadialGradient(x,y,0,x,y,r);
  g.addColorStop(0,col+'.1)');g.addColorStop(.5,col+'.03)');g.addColorStop(1,col+'0)');
  cx.fillStyle=g;cx.beginPath();cx.arc(x,y,r,0,TAU);cx.fill();cx.globalAlpha=1;
}

function hueCol(base,shift){
  const r=parseInt(base.slice(1,3),16),g=parseInt(base.slice(3,5),16),b=parseInt(base.slice(5,7),16);
  return`rgb(${cl(r+shift,0,255)},${cl(g+shift*.7,0,255)},${cl(b-shift*.3,0,255)})`;
}

// ═══ NEBULA BACKGROUND ═══
const neb=document.createElement('canvas');neb.width=neb.height=512;
(()=>{const c=neb.getContext('2d');c.fillStyle='#010810';c.fillRect(0,0,512,512);
[{x:100,y:80,r:200,c:'rgba(0,30,60,.06)'},{x:400,y:130,r:180,c:'rgba(40,0,50,.05)'},
{x:250,y:380,r:260,c:'rgba(0,25,50,.07)'},{x:60,y:430,r:150,c:'rgba(30,20,0,.04)'},
{x:400,y:400,r:180,c:'rgba(0,40,35,.04)'}].forEach(b=>{const g=c.createRadialGradient(b.x,b.y,0,b.x,b.y,b.r);g.addColorStop(0,b.c);g.addColorStop(1,'transparent');c.fillStyle=g;c.fillRect(0,0,512,512);});
