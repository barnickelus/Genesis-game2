<script type="module">
import*as THREE from'https://cdn.jsdelivr.net/npm/three@0.153.0/build/three.module.js';
import{GLTFLoader}from'https://cdn.jsdelivr.net/npm/three@0.153.0/examples/jsm/loaders/GLTFLoader.js';
const T=window.TILE,S=window.SCALE,hc=document.getElementById('headCanvas');
const r=new THREE.WebGLRenderer({canvas:hc,alpha:true,antialias:true});r.setSize(T*S,T*S);
const sc=new THREE.Scene(),cam=new THREE.PerspectiveCamera(40,1,.1,100);cam.position.set(0,0,5);
const dl=new THREE.DirectionalLight(0xffffff,1.2);dl.position.set(1,2,3);sc.add(dl);sc.add(new THREE.AmbientLight(0xffffff,.35));
let hm=null;new GLTFLoader().load('dragon-head.glb',g=>{hm=g.scene;const b=new THREE.Box3().setFromObject(hm);const sz=b.getSize(new THREE.Vector3()).length();hm.scale.setScalar(2/Math.max(sz,.001));b.setFromObject(hm);hm.position.copy(b.getCenter(new THREE.Vector3()).negate());hm.rotation.order='YXZ';sc.add(hm);},undefined,()=>{});
window.renderHead=(yaw,pitch)=>{if(!hm)return;hm.rotation.y=yaw;hm.rotation.x=pitch;r.render(sc,cam);};
