    cx.globalAlpha=bv*.52;cx.beginPath();cx.arc(0,0,r*br,0,TAU);cx.fill();
    cx.fillStyle=s.c.dim;cx.globalAlpha=.3;for(let i=0;i<8;i++){const sa=(i/8)*TAU+ts*.0012,tip=r*1.45+Math.sin(ts*.003+i)*r*.08;cx.beginPath();cx.moveTo(Math.cos(sa-.07)*r*.82,Math.sin(sa-.07)*r*.82);cx.lineTo(Math.cos(sa)*tip,Math.sin(sa)*tip);cx.lineTo(Math.cos(sa+.07)*r*.82,Math.sin(sa+.07)*r*.82);cx.fill();}
    for(let s2=-1;s2<=1;s2++){const ed=s2===0?r*.4:r*.35;cx.fillStyle='#fff';cx.globalAlpha=bv*.85;cx.beginPath();cx.arc(ed,s2*.22,r*(s2===0?.11:.08),0,TAU);cx.fill();cx.fillStyle='#e85010';cx.globalAlpha=1;cx.beginPath();cx.arc(ed+r*.01,s2*.22,r*(s2===0?.05:.035),0,TAU);cx.fill();}
    cx.fillStyle='rgba(255,255,255,.18)';cx.shadowBlur=6*zm;cx.shadowColor=C.primo.pri;cx.beginPath();cx.arc(0,0,r*.22,0,TAU);cx.fill();
  }
  cx.restore();
  if(shOn){const rem=shTime/5000;cx.strokeStyle=`rgba(232,192,64,${.18*rem})`;cx.lineWidth=1;cx.shadowBlur=8*zm;cx.shadowColor='#e8c040';cx.beginPath();cx.arc(P.x,P.y,r*1.25,0,TAU);cx.stroke();cx.shadowBlur=0;}
  if(P.dash){cx.globalCompositeOperation='lighter';cx.fillStyle=c;cx.globalAlpha=.15;cx.beginPath();cx.arc(P.x-P.vx*3,P.y-P.vy*3,r*.55,0,TAU);cx.fill();cx.beginPath();cx.arc(P.x-P.vx*5,P.y-P.vy*5,r*.35,0,TAU);cx.fill();cx.globalCompositeOperation='source-over';}
  if(P.flash.t>0){cx.fillStyle=P.flash.c;cx.globalAlpha=.18*(P.flash.t/400);cx.beginPath();cx.arc(P.x,P.y,r*1.3,0,TAU);cx.fill();}
  cx.shadowBlur=0;cx.globalAlpha=1;
}

// ═══ DRAW FRENZY ORBS ═══
function drawFrenzyOrbs(ts){
  if(!frenzy||!frenzyOrbs.length)return;
  for(const orb of frenzyOrbs){
    const ox=P.x+Math.cos(orb.ang)*orb.dist;
    const oy=P.y+Math.sin(orb.ang)*orb.dist;
    if(!onScr(ox,oy,orb.r*3))continue;
    cx.shadowBlur=6*zm;cx.shadowColor=orb.col;
    cx.fillStyle=orb.col;cx.globalAlpha=.6+.2*Math.sin(ts*.006+orb.ang);
    cx.beginPath();cx.arc(ox,oy,orb.r,0,TAU);cx.fill();
    cx.fillStyle='rgba(255,255,255,.3)';cx.globalAlpha=.5;
    cx.beginPath();cx.arc(ox,oy,orb.r*.3,0,TAU);cx.fill();
  }
  cx.shadowBlur=0;cx.globalAlpha=1;
}

// ═══ BACKGROUND / GRID / DUST / PICKUPS ═══
function drawBg(ts){
  const tl=1024,ox=(-P.x*.02)%tl,oy=(-P.y*.02)%tl;cx.globalAlpha=.5;
  for(let nx=-1;nx<=Math.ceil(W/tl)+1;nx++)for(let ny=-1;ny<=Math.ceil(H/tl)+1;ny++)cx.drawImage(neb,ox+nx*tl,oy+ny*tl,tl,tl);cx.globalAlpha=1;
  for(const s of stars){const sx2=(s.x-P.x*s.dp)*zm+off.x+shx,sy2=(s.y-P.y*s.dp)*zm+off.y+shy;if(sx2<-3||sx2>W+3||sy2<-3||sy2>H+3)continue;const tw=.2+.8*(.5+.5*Math.sin(ts*s.tw*.001+s.ph));cx.globalAlpha=tw*.55;cx.fillStyle=s.c;if(s.s>1.1){cx.fillRect(sx2-s.s,sy2-.2,s.s*2,.4);cx.fillRect(sx2-.2,sy2-s.s,.4,s.s*2);}cx.fillRect(sx2,sy2,s.s*.7,s.s*.7);}cx.globalAlpha=1;
}

function drawGrid(){
  // Minor grid
  cx.lineWidth=.25;
  for(let i=-16;i<=16;i++)for(let j=-16;j<=16;j++){const x=i*50,y=j*50;if(!onScr(x,y,50))continue;const dd=Math.hypot(x+25-P.x,y+25-P.y);const f=Math.max(0,1-dd/350);if(f<.01)continue;cx.strokeStyle=`rgba(18,28,40,${.06*f})`;cx.beginPath();cx.rect(x,y,50,50);cx.stroke();}
  // Major grid
  cx.lineWidth=.5;
  for(let i=-8;i<=8;i++)for(let j=-8;j<=8;j++){const x=i*200,y=j*200;if(!onScr(x,y,300))continue;const dd=Math.hypot(x+100-P.x,y+100-P.y);const f=Math.max(0,1-dd/800);cx.strokeStyle=`rgba(24,36,52,${.12*f+.015})`;cx.beginPath();cx.rect(x,y,200,200);cx.stroke();}
  // Landmarks
  for(const lm of LANDMARKS){if(!onScr(lm.x,lm.y,lm.s*6))continue;const dd=Math.hypot(lm.x-P.x,lm.y-P.y);if(dd>700)continue;const fade=Math.max(0,1-dd/700);cx.fillStyle=`rgba(14,22,34,${.12*fade})`;
  for(const rk of lm.rocks){cx.globalAlpha=fade*.08;cx.beginPath();cx.ellipse(lm.x+Math.cos(rk.a)*lm.s*rk.d,lm.y+Math.sin(rk.a)*lm.s*rk.d,lm.s*rk.r,lm.s*rk.r*.65,rk.a,0,TAU);cx.fill();}
  cx.fillStyle=`rgba(60,140,120,${.05*fade})`;cx.beginPath();cx.arc(lm.x,lm.y-lm.s*.7,lm.s*.2,0,TAU);cx.fill();}cx.globalAlpha=1;
  // Distance rings
  cx.strokeStyle='rgba(20,35,50,.04)';cx.lineWidth=.5;for(let ring=1;ring<=4;ring++){const rr=ring*400;if(!onScr(0,0,rr+50))continue;cx.beginPath();cx.arc(0,0,rr,0,TAU);cx.stroke();}
  if(onScr(0,0,20)){cx.strokeStyle='rgba(40,70,90,.08)';cx.lineWidth=.6;cx.beginPath();cx.moveTo(-12,0);cx.lineTo(12,0);cx.stroke();cx.beginPath();cx.moveTo(0,-12);cx.lineTo(0,12);cx.stroke();}
}

function drawDust(ts){
  while(dust.length<50)dust.push({x:P.x+rng(-W/zm,W/zm),y:P.y+rng(-H/zm,H/zm),s:rng(.2,.9),vx:rng(-.03,.03),vy:rng(-.03,.03),a:rng(.012,.045),ph:rng(0,TAU)});
  for(const d of dust){d.x+=d.vx;d.y+=d.vy;if(!onScr(d.x,d.y,5)){d.x=P.x+rng(-W/zm,W/zm);d.y=P.y+rng(-H/zm,H/zm);}cx.fillStyle='rgba(160,200,240,'+d.a*(.5+.5*Math.sin(ts*.001+d.ph))+')';cx.beginPath();cx.arc(d.x,d.y,d.s,0,TAU);cx.fill();}
}

function drawPicks(ts){
  if(pill.on){bioGlow(pill.x,pill.y,pill.r*3.5,C.drifter.gl,.35);cx.shadowBlur=8*zm;cx.shadowColor=C.drifter.pri;cx.fillStyle=C.drifter.pri;cx.globalAlpha=.55;cx.beginPath();cx.arc(pill.x,pill.y,pill.r*(1+.12*Math.sin(ts*.005)),0,TAU);cx.fill();cx.fillStyle='rgba(255,255,255,.25)';cx.beginPath();cx.arc(pill.x,pill.y,pill.r*.28,0,TAU);cx.fill();cx.shadowBlur=0;cx.globalAlpha=1;}
  if(shld.on){bioGlow(shld.x,shld.y,shld.r*3.5,C.primo.gl,.35);cx.shadowBlur=8*zm;cx.shadowColor=C.primo.pri;cx.fillStyle=C.primo.pri;cx.globalAlpha=.55;cx.beginPath();cx.arc(shld.x,shld.y,shld.r*(1+.1*Math.sin(ts*.006)),0,TAU);cx.fill();cx.fillStyle='rgba(255,255,255,.25)';cx.beginPath();cx.arc(shld.x,shld.y,shld.r*.28,0,TAU);cx.fill();cx.shadowBlur=0;cx.globalAlpha=1;}
  beacons.forEach(b=>{if(!onScr(b.x,b.y,b.r*2))return;cx.fillStyle='rgba(200,220,255,.3)';cx.globalAlpha=.35+.1*Math.sin(ts*.003);cx.beginPath();cx.arc(b.x,b.y,b.r,0,TAU);cx.fill();cx.globalAlpha=1;});
}

function drawVig(){cx.setTransform(1,0,0,1,0,0);const g=cx.createRadialGradient(W/2,H/2,W*.18,W/2,H/2,W*.65);g.addColorStop(0,'transparent');g.addColorStop(1,'rgba(1,8,16,.55)');cx.fillStyle=g;cx.fillRect(0,0,W,H);}

// ═══ RADAR / MINIMAP / HUD / HEAD / JOYSTICK ═══
const rc=document.getElementById('radar').getContext('2d');
function drawRadar(){rc.clearRect(0,0,68,68);rc.fillStyle='rgba(0,0,0,.2)';rc.fillRect(0,0,68,68);const sw=gt*.002%TAU;rc.strokeStyle='rgba(100,200,180,.2)';rc.lineWidth=.6;rc.beginPath();rc.moveTo(34,34);rc.lineTo(34+Math.cos(sw)*32,34+Math.sin(sw)*32);rc.stroke();rc.fillStyle=stg().c.pri;rc.beginPath();rc.arc(34,34,2,0,TAU);rc.fill();const rng2=Math.max(1600,Math.hypot(P.x,P.y)*1.1),sc=64/(rng2*2);for(const o of orgs){const T=ORGS[o.type],dx2=(o.x-P.x)*sc+34,dy2=(o.y-P.y)*sc+34;if(dx2<2||dx2>66||dy2<2||dy2>66)continue;rc.fillStyle=o.type==='echo'?C.mirrGl:canEat(o)?'#5a5':isPred(o)?'#a44':T.col;rc.beginPath();rc.arc(dx2,dy2,cl(o.r*.04,.4,1.6),0,TAU);rc.fill();}}

const mc=document.getElementById('minimapC').getContext('2d');
function drawMM(){mc.clearRect(0,0,76,76);mc.fillStyle='rgba(1,8,16,.35)';mc.fillRect(0,0,76,76);const sc=72/3200;for(const o of orgs){const T=ORGS[o.type],dx2=(o.x-P.x)*sc+38,dy2=(o.y-P.y)*sc+38;if(dx2<2||dx2>74||dy2<2||dy2>74)continue;mc.fillStyle=o.type==='echo'?C.mirrGl:canEat(o)?'#5a5':isPred(o)?'#a44':T.col;mc.beginPath();mc.arc(dx2,dy2,cl(o.r*.05,.4,1.6),0,TAU);mc.fill();}mc.fillStyle=stg().c.pri;mc.beginPath();mc.arc(38,38,2,0,TAU);mc.fill();}

function updateHead(){const w=document.getElementById('dragonHead'),sz=TILE*SCALE*Math.min(1.3,.8+(P.r/18));const sx2=P.x*zm+off.x+shx,sy2=P.y*zm+off.y+shy;w.style.width=sz+'px';w.style.height=sz+'px';w.style.left=(sx2-sz/2)+'px';w.style.top=(sy2-sz/2)+'px';document.getElementById('headCanvas').style.width=sz+'px';document.getElementById('headCanvas').style.height=sz+'px';if(typeof window.renderHead==='function'){const yT=(P.hd+PI)/TAU;window.renderHead((yT%1)*TAU,(cl(Math.hypot(P.vx,P.vy)/3,0,1)*.5-.25)*PI);}}

function drawJK(){if(!jctx)return;jctx.clearRect(0,0,100,100);jctx.fillStyle='rgba(255,255,255,.04)';jctx.beginPath();jctx.arc(50,50,44,0,TAU);jctx.fill();if(jkAct){jctx.fillStyle='rgba(255,255,255,.12)';jctx.beginPath();jctx.arc(50+jkX*26,50+jkY*26,12,0,TAU);jctx.fill();}}

const cdC=document.getElementById('cdRing').getContext('2d');
function updateHUD(){
  const s=stg(),nx=STAGES[P.stg+1];
  document.getElementById('stgLbl').textContent=s.name;document.getElementById('stgLbl').style.color=s.c.pri;document.getElementById('stgLbl').style.textShadow=`0 0 12px ${s.c.pri},0 0 30px ${s.c.dim}`;
  document.getElementById('massV').textContent=Math.floor(P.mass);document.getElementById('scoreLbl').textContent=score.toLocaleString();
  document.getElementById('abilLbl').textContent=s.abT+(streak>1?`  ${streak}x`:'');
  const bar=document.getElementById('evoFill');
  if(nx){const pct=cl((P.mass-s.thr)/(nx.thr-s.thr)*100,0,100);bar.style.width=pct+'%';bar.style.background=`linear-gradient(90deg,${s.c.pri},${nx.c.pri})`;document.getElementById('evoNxt').textContent=`${nx.name} — ${nx.thr}`;}
  else{bar.style.width='100%';bar.style.background=s.c.pri;document.getElementById('evoNxt').textContent='APEX';}
  cdC.clearRect(0,0,24,24);if(s.cd>0){const pct2=1-abil_cd/s.cd;cdC.strokeStyle=s.c.pri;cdC.lineWidth=1.5;cdC.beginPath();cdC.arc(12,12,9,-PI/2,-PI/2+pct2*TAU);cdC.stroke();cdC.strokeStyle='rgba(255,255,255,.04)';cdC.beginPath();cdC.arc(12,12,9,0,TAU);cdC.stroke();}
  const hpPct=(P.mass-STAGES[P.stg].thr*.85)/(Math.max(1,STAGES[P.stg].thr*.15));
  document.getElementById('dangerV').style.opacity=hpPct<.3?(.3-hpPct)/.3*.5:0;
}

// ═══ MAIN LOOP ═══
let lt=0;
function loop(ts){
  requestAnimationFrame(loop);
  if(paused){lt=ts;return;}
  const dt=Math.min(ts-lt,50)||16;lt=ts;gt+=dt;

  // Shake
  if(shd>0){shd-=dt;const t=cl(shd/300,0,1);shx=(Math.random()-.5)*shi*t*2;shy=(Math.random()-.5)*shi*t*2;}else{shx=shy=0;shi=0;}

  // Update
  rebuildGrid();
  updateP(dt);
  for(const o of orgs)aiOrg(o,dt);
  collide(dt);
  ecoCollide();

  // Camera
  const tz=cl(H/(P.r*5.5),.3,1.5);zm=lp(zm,tz,.04);
  off.x=W/2-P.x*zm;off.y=H/2-P.y*zm;

  // Ecosystem maintenance
  for(const[type,T]of Object.entries(ORGS)){if(type==='echo')continue;const cnt=orgs.filter(o=>o.type===type).length;if(cnt<T.mx*.35)spawn(type,1);}

  // ── DRAW ──
  cx.setTransform(1,0,0,1,0,0);cx.clearRect(0,0,W,H);
  drawBg(ts);
  cx.setTransform(zm,0,0,zm,off.x+shx,off.y+shy);
  drawGrid();drawDust(ts);

  // Particles
  for(let i=parts.length-1;i>=0;i--){const p=parts[i];p.x+=p.vx;p.y+=p.vy;p.vx*=.97;p.vy*=.97;p.life-=dt;if(p.life<=0){parts.splice(i,1);continue;}const a=cl(p.life/p.ml,0,1);cx.fillStyle=p.c;cx.globalAlpha=a*(p.t==='lure'?.3*(.5+.5*Math.sin(ts*.01)):.45);cx.beginPath();cx.arc(p.x,p.y,p.r*a,0,TAU);cx.fill();}
  cx.globalAlpha=1;

  // Organisms
  for(const o of orgs)drawCreature(o,ts);

  // Projectiles
  for(const p of projs){cx.fillStyle=p.c;cx.globalAlpha=.75;cx.shadowBlur=6*zm;cx.shadowColor=p.c;cx.beginPath();cx.arc(p.x,p.y,p.r,0,TAU);cx.fill();cx.fillStyle='rgba(255,255,255,.35)';cx.beginPath();cx.arc(p.x,p.y,p.r*.3,0,TAU);cx.fill();cx.shadowBlur=0;cx.globalAlpha=1;}

  drawPicks(ts);drawFrenzyOrbs(ts);drawP(ts);

  // Float texts
  cx.font='500 12px "Tenor Sans",serif';cx.textAlign='center';
  for(let i=txts.length-1;i>=0;i--){const f=txts[i];f.y-=.6*(dt/16);f.life-=dt;if(f.life<=0){txts.splice(i,1);continue;}cx.fillStyle=f.c;cx.globalAlpha=cl(f.life/f.ml,0,1);cx.fillText(f.t,f.x,f.y);}cx.globalAlpha=1;

  // Frenzy tint
  if(frenzy){cx.setTransform(1,0,0,1,0,0);cx.globalAlpha=.025+.012*Math.sin(ts*.007);cx.fillStyle='#4080f0';cx.fillRect(0,0,W,H);cx.globalAlpha=1;}

  drawVig();updateHUD();if(radarOn)drawRadar();drawMM();drawJK();updateHead();
}

init();
requestAnimationFrame(loop);
</script>
